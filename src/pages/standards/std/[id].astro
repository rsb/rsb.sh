---
import { getEntry, render } from "astro:content";
import DecisionLog from "../../../layouts/DecisionLog.astro";
import StandardsSidebar from "../../../components/StandardsSidebar.astro";

// Per-standard page (standards plan §5.2). On-demand; single-segment [id] (the
// entry id = citable id, e.g. STD-NAMING, case-preserving through canonicalUrl).
export const prerender = false;

const { id } = Astro.params;
const entry = id ? await getEntry("standards", id) : undefined;

if (!entry) {
  return new Response("Not found", { status: 404 });
}

const { Content } = await render(entry);

// Backlink UP to the source decision. check-corpus.ts guarantees sourceAdr is a
// non-draft ADR, so the /adr/ path (not /draft/) is always correct.
const site = Astro.site ?? new URL("https://rsb.sh");
const sourceHref = `https://adrs.${site.host}/adr/${entry.data.sourceAdr.id}/`;

// The reason this surface exists: the exact string a released crate uses to cite
// this standard, built from the REAL corpusVersion field (never hardcoded).
const citeString = `Complies with ${entry.id} (corpus v${entry.data.corpusVersion})`;

// Long-but-revalidating — NOT immutable: a standard is revisable (a corpus bump
// changes this page).
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400",
);
---

<DecisionLog surface="Standards" title={`${entry.id} · ${entry.data.title}`}>
  <StandardsSidebar slot="sidebar" />

  <article class="max-w-prose">
    <p class="font-mono text-sm text-neutral-500">{entry.id}</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight">{entry.data.title}</h1>
    <p class="mt-3 text-xs uppercase tracking-wide text-neutral-400">corpus v{entry.data.corpusVersion}</p>

    <div class="mt-6 text-neutral-800 [&_h2]:mt-8 [&_h2]:text-lg [&_h2]:font-semibold [&_p]:mt-3 [&_p]:leading-relaxed [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:pl-6">
      <Content />
    </div>

    <footer class="mt-10 space-y-6 border-t border-neutral-200 pt-6 text-sm">
      <p class="text-neutral-600">
        <span class="font-medium text-neutral-900">Source decision:</span>{" "}
        <a href={sourceHref} class="underline hover:no-underline">{entry.data.sourceAdr.id}</a>
      </p>

      <div>
        <p class="font-medium text-neutral-900">How to cite this</p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <code
            id="cite-string"
            class="rounded bg-neutral-100 px-2 py-1 font-mono text-xs text-neutral-800"
          >
            {citeString}
          </code>
          <button
            id="cite-copy"
            type="button"
            data-cite={citeString}
            class="rounded border border-neutral-300 px-2 py-1 text-xs text-neutral-700 transition-colors hover:bg-neutral-100"
          >
            Copy
          </button>
        </div>
      </div>
    </footer>
  </article>

  <script>
    // Externalized (no `is:inline`) → served from self, CSP-safe.
    const btn = document.getElementById("cite-copy") as HTMLButtonElement | null;
    btn?.addEventListener("click", async () => {
      const text = btn.dataset.cite ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied";
        setTimeout(() => (btn.textContent = original), 1500);
      } catch {
        // Clipboard unavailable — the string stays selectable in the <code> block.
      }
    });
  </script>
</DecisionLog>
