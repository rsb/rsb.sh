---
import { getCollection } from "astro:content";
import DecisionLog from "../../layouts/DecisionLog.astro";
import StandardsSidebar from "../../components/StandardsSidebar.astro";

// standards.rsb.sh landing (standards plan §5.2). On-demand so host routing runs.
// At-a-glance corpus version intentionally omitted (decision B) — the real version
// lives on each standard's "how to cite" string.
export const prerender = false;

const standards = await getCollection("standards");
const empty = standards.length === 0;
---

<DecisionLog
  surface="Standards"
  title="Standards"
  description="Normative standards for the RSB ecosystem — driven by accepted decisions, corpus-versioned, and cited by released crates."
>
  <StandardsSidebar slot="sidebar" />

  <h1 class="text-2xl font-semibold tracking-tight">Standards</h1>
  <p class="mt-4 max-w-prose text-neutral-600">
    Standards are the normative rules of the RSB ecosystem. Each codifies exactly
    one accepted decision — the <a
      href="https://adrs.rsb.sh"
      class="underline hover:no-underline">ADR</a
    > records why, the standard states the requirement, released code complies — and
    carries a stable, citable id (e.g. <code class="font-mono text-sm">STD-NAMING</code>).
    Standards are corpus-versioned: a crate pinned to an earlier corpus resolves the
    standard as it stood then, so released code never breaks under a later rule change.
  </p>

  {empty && <p class="mt-8 text-neutral-500">No standards have been published yet.</p>}
</DecisionLog>
