---
import { getCollection, getEntry, render } from "astro:content";
import DecisionLog from "../../../layouts/DecisionLog.astro";
import AdrSidebar from "../../../components/AdrSidebar.astro";

// Per-ADR page for DRAFTS (ADR plan §5.7). On-demand; single-segment [slug]. A
// non-draft entry 404s here — accepted/deprecated live under /adr/[slug] — so one
// entry never surfaces under two URLs.
export const prerender = false;

const { slug } = Astro.params;
const entry = slug ? await getEntry("adrs", slug) : undefined;

if (!entry || entry.data.status !== "draft") {
  return new Response("Not found", { status: 404 });
}

const { Content } = await render(entry);

// A draft may declare intent to supersede existing ADRs (schema allows it).
const all = await getCollection("adrs");
const byId = new Map(all.map((a) => [a.id, a]));
const adrHref = (id: string) =>
  byId.get(id)?.data.status === "draft" ? `/draft/${id}/` : `/adr/${id}/`;

// Drafts change freely — do not cache.
Astro.response.headers.set("Cache-Control", "no-store");

const reversibilityLabel: Record<string, string> = {
  bedrock: "bedrock",
  "hard-to-reverse": "hard to reverse",
  reversible: "reversible",
};
---

<DecisionLog surface="Decisions" title={`Draft · ${entry.data.title}`}>
  <AdrSidebar slot="sidebar" />

  <article class="max-w-prose">
    <p class="font-mono text-sm text-neutral-500">Draft</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight">{entry.data.title}</h1>

    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs uppercase tracking-wide">
      <span class="rounded bg-neutral-200 px-1.5 py-0.5 text-neutral-700">draft</span>
      <span class="rounded bg-neutral-100 px-1.5 py-0.5 text-neutral-600">
        {reversibilityLabel[entry.data.reversibility]}
      </span>
    </div>

    <p class="mt-4 rounded border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm text-neutral-600">
      This decision is still a draft — it has no number and is not yet part of the
      governing record.
    </p>

    <div class="mt-6 text-neutral-800 [&_h2]:mt-8 [&_h2]:text-lg [&_h2]:font-semibold [&_p]:mt-3 [&_p]:leading-relaxed [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:pl-6">
      <Content />
    </div>

    {
      entry.data.supersedes?.length ? (
        <footer class="mt-10 border-t border-neutral-200 pt-6 text-sm">
          <p class="text-neutral-600">
            <span class="font-medium text-neutral-900">Intends to supersede:</span>{" "}
            {entry.data.supersedes.map((r, i) => (
              <>
                {i > 0 && ", "}
                <a href={adrHref(r.id)} class="underline hover:no-underline">
                  {r.id}
                </a>
              </>
            ))}
          </p>
        </footer>
      ) : null
    }
  </article>
</DecisionLog>
