---
import { getCollection, getEntry, render } from "astro:content";
import DecisionLog from "../../../layouts/DecisionLog.astro";
import AdrSidebar from "../../../components/AdrSidebar.astro";

// Per-ADR page for ACCEPTED/DEPRECATED decisions (ADR plan §5.7). On-demand;
// single-segment [slug] (the entry id, e.g. 0003-rsb-is-the-opinion). A draft
// entry 404s here — drafts live under /draft/[slug] — so one entry never surfaces
// under two URLs.
export const prerender = false;

const { slug } = Astro.params;
const entry = slug ? await getEntry("adrs", slug) : undefined;

if (!entry || entry.data.status === "draft") {
  return new Response("Not found", { status: 404 });
}

// Narrow to the numbered (accepted/deprecated) shape now that draft is excluded.
const data = entry.data as Extract<typeof entry.data, { number: number }>;
const { Content } = await render(entry);

// Resolve supersedes targets and the DERIVED superseded-by (a non-draft ADR whose
// `supersedes` names this one). Both need the full collection.
const all = await getCollection("adrs");
const byId = new Map(all.map((a) => [a.id, a]));
const supersededBy = all.find(
  (a) => a.data.status !== "draft" && (a.data.supersedes ?? []).some((r) => r.id === entry.id),
);

const site = Astro.site ?? new URL("https://rsb.sh");
const standardsHref = (id: string) => `https://standards.${site.host}/std/${id}/`;
// Absolute, like standardsHref: this page is also reachable via the non-canonical
// apex duplicate (rsb.sh/adrs/adr/…), where a host-relative /adr/{id}/ would
// resolve against the apex and 404. Pin cross-links to the adrs. subdomain.
const adrHref = (id: string) =>
  byId.get(id)?.data.status === "draft"
    ? `https://adrs.${site.host}/draft/${id}/`
    : `https://adrs.${site.host}/adr/${id}/`;

const reversibilityLabel: Record<string, string> = {
  bedrock: "bedrock",
  "hard-to-reverse": "hard to reverse",
  reversible: "reversible",
};
const dateAccepted = data.dateAccepted.toISOString().slice(0, 10);
---

<DecisionLog surface="Decisions" title={`ADR-${String(data.number).padStart(4, "0")} · ${data.title}`}>
  <AdrSidebar slot="sidebar" />

  <article class="prose-rsb max-w-prose">
    <p class="font-mono text-sm text-neutral-500">ADR-{String(data.number).padStart(4, "0")}</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight">{data.title}</h1>

    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs uppercase tracking-wide">
      <span
        class:list={[
          "rounded px-1.5 py-0.5",
          data.status === "deprecated"
            ? "bg-amber-100 text-amber-800"
            : "bg-emerald-100 text-emerald-800",
        ]}
      >
        {data.status}
      </span>
      <span class="rounded bg-neutral-100 px-1.5 py-0.5 text-neutral-600">
        {reversibilityLabel[data.reversibility]}
      </span>
      <span class="text-neutral-400">accepted {dateAccepted}</span>
      <span class="text-neutral-400">corpus v{data.corpusVersion}</span>
    </div>

    {
      supersededBy && (
        <p class="mt-4 rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900">
          Superseded by{" "}
          <a href={adrHref(supersededBy.id)} class="font-medium underline hover:no-underline">
            ADR-{String((supersededBy.data as { number: number }).number).padStart(4, "0")} ·{" "}
            {supersededBy.data.title}
          </a>
          .
        </p>
      )
    }

    <div class="mt-6 text-neutral-800 [&_h2]:mt-8 [&_h2]:text-lg [&_h2]:font-semibold [&_p]:mt-3 [&_p]:leading-relaxed [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:pl-6 [&_a]:underline [&_a:hover]:no-underline">
      <Content />
    </div>

    {
      (data.supersedes?.length || data.drives?.length) && (
        <footer class="mt-10 border-t border-neutral-200 pt-6 text-sm">
          {data.supersedes?.length ? (
            <p class="text-neutral-600">
              <span class="font-medium text-neutral-900">Supersedes:</span>{" "}
              {data.supersedes.map((r, i) => (
                <>
                  {i > 0 && ", "}
                  <a href={adrHref(r.id)} class="underline hover:no-underline">
                    {r.id}
                  </a>
                </>
              ))}
            </p>
          ) : null}
          {data.drives?.length ? (
            <p class="mt-2 text-neutral-600">
              <span class="font-medium text-neutral-900">Drives standards:</span>{" "}
              {data.drives.map((r, i) => (
                <>
                  {i > 0 && ", "}
                  <a href={standardsHref(r.id)} class="underline hover:no-underline">
                    {r.id}
                  </a>
                </>
              ))}
            </p>
          ) : null}
        </footer>
      )
    }
  </article>
</DecisionLog>
