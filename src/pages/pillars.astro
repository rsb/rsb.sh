---
// /pillars moved into the Architecture section at /architecture/pillars
// (site-shell restructure). The /pillars URL just shipped (PRs #24, #25), so it
// 301-redirects to the new home rather than breaking.
//
// This MUST stay an on-demand route (not a static `redirects` config / _redirects
// entry): a static redirect is served from the assets layer before middleware and
// would fire on EVERY host, including adrs./standards. As an on-demand page the
// host-routing middleware runs first — on the apex it redirects; on a host-routed
// subdomain the request is rewritten into /adrs|/standards (no /pillars there), so
// it 404s and never leaks the redirect onto those surfaces.
export const prerender = false;

// A permanent move is the most cacheable response here, but Cloudflare won't cache
// an origin 301 without an explicit header — so set one, matching the restructure's
// "no uncached origin hits" rule for on-demand routes. Built as an explicit Response
// rather than Astro.redirect() + Astro.response.headers: returning a Response from
// the frontmatter short-circuits rendering, so headers set on Astro.response would
// be dropped. The host-routing middleware still layers the security headers on top
// (and still rewrites adrs./standards. away before this page runs, so it 404s there).
return new Response(null, {
  status: 301,
  headers: {
    Location: "/architecture/pillars",
    "Cache-Control": "public, max-age=300, s-maxage=86400",
  },
});
---
