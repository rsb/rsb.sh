---
import "../styles/global.css";
import { canonicalUrl } from "../host-routes";
import SiteHeader from "../components/SiteHeader.astro";
import Footer from "../components/Footer.astro";

// These pages are served from the adrs./standards. subdomains, where the shared
// header/footer's internal links must point back to the apex (a root-relative
// "/why" here is host-rewritten into this subtree and 404s). Base it on the apex.
const APEX = "https://rsb.sh";

// Two-pane decision-log shell (ADR plan §5.4), modeled on Log4Brains: a left
// index rail + a right reading pane. Deliberately surface-agnostic so both
// adrs.rsb.sh and standards.rsb.sh reuse it — each supplies its OWN index via the
// `sidebar` named slot, so neither inherits the other's listing.
interface Props {
  surface: string; // surface name shown beside the wordmark, e.g. "Decisions"
  title?: string; // <title> / canonical context; defaults to the surface name
  description?: string;
}

const { surface, title = surface, description } = Astro.props;

// Same canonical collapse as Base.astro: the host-routed /adrs|/standards paths
// canonicalize to their real subdomain origin.
const site = Astro.site ?? new URL("https://rsb.sh");
const canonical = canonicalUrl(Astro.url.pathname, site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title} — rsb.sh</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="flex min-h-screen flex-col bg-white text-neutral-900">
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-20 focus:rounded focus:bg-neutral-900 focus:px-3 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>

    <SiteHeader base={APEX} />

    <!-- Same two-pane shell as Base's sidebar branch, for one uniform site frame:
         a fixed-width index rail + a content pane whose readable measure is centred
         (mx-auto) within the pane. The rail stacks above the content on mobile (no
         JS toggle — that lived in the old breadcrumb header). -->
    <div class="flex flex-1 flex-col md:flex-row">
      <nav
        aria-label={`${surface} index`}
        class="border-b border-neutral-200 px-6 py-8 md:w-64 md:shrink-0 md:border-b-0 md:border-r"
      >
        <slot name="sidebar" />
      </nav>

      <main id="content" class="min-w-0 flex-1 px-6 py-10 md:px-12">
        <div class="mx-auto max-w-3xl">
          <slot />
        </div>
      </main>
    </div>

    <Footer />
  </body>
</html>
