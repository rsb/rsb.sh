---
import "../styles/global.css";
import { canonicalUrl } from "../host-routes";

// Two-pane decision-log shell (ADR plan §5.4), modeled on Log4Brains: a left
// index rail + a right reading pane. Deliberately surface-agnostic so both
// adrs.rsb.sh and standards.rsb.sh reuse it — each supplies its OWN index via the
// `sidebar` named slot, so neither inherits the other's listing.
interface Props {
  surface: string; // surface name shown beside the wordmark, e.g. "Decisions"
  title?: string; // <title> / canonical context; defaults to the surface name
  description?: string;
}

const { surface, title = surface, description } = Astro.props;

// Same canonical collapse as Base.astro: the host-routed /adrs|/standards paths
// canonicalize to their real subdomain origin.
const site = Astro.site ?? new URL("https://rsb.sh");
const canonical = canonicalUrl(Astro.url.pathname, site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title} — rsb.sh</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="min-h-screen bg-white text-neutral-900">
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-20 focus:rounded focus:bg-neutral-900 focus:px-3 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>

    <header
      class="flex flex-wrap items-baseline gap-x-4 gap-y-1 border-b border-neutral-200 px-6 py-4"
    >
      <a
        href="https://rsb.sh"
        class="font-mono text-sm tracking-wide text-neutral-900"
        aria-label="rsb.sh home"
      >
        rsb.sh
      </a>
      <span aria-hidden="true" class="text-neutral-300">/</span>
      <a href="/" class="text-sm text-neutral-600 transition-colors hover:text-neutral-900">
        {surface}
      </a>

      <!-- Sidebar toggle: only meaningful on narrow viewports (md:hidden). -->
      <button
        id="sidebar-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="surface-nav"
        class="ml-auto rounded border border-neutral-300 px-2 py-1 text-sm text-neutral-700 md:hidden"
      >
        Index
      </button>
    </header>

    <!-- Sidebar pinned to the left edge as a thin fixed-width rail; content sits
         beside it and is constrained to a readable measure. No outer centering —
         centering left a wide gutter that read as the sidebar owning the left half. -->
    <div class="flex w-full flex-col md:flex-row">
      <nav
        id="surface-nav"
        aria-label={`${surface} index`}
        data-collapsed
        class="border-b border-neutral-200 px-6 py-6 data-[collapsed]:hidden md:block md:w-64 md:shrink-0 md:border-b-0 md:border-r md:data-[collapsed]:block"
      >
        <slot name="sidebar" />
      </nav>

      <main id="content" class="min-w-0 flex-1 px-6 py-10 md:px-10">
        <div class="max-w-3xl">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Externalized by Astro (no `is:inline`) → served from self, so it passes
      // the strict `script-src 'self'` CSP with no inline-script exception.
      const toggle = document.getElementById("sidebar-toggle");
      const nav = document.getElementById("surface-nav");
      toggle?.addEventListener("click", () => {
        const open = nav?.hasAttribute("data-collapsed");
        if (open) nav?.removeAttribute("data-collapsed");
        else nav?.setAttribute("data-collapsed", "");
        toggle.setAttribute("aria-expanded", String(open));
      });
    </script>
  </body>
</html>
