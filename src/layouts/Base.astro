---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "rsb.sh",
  description = "Open-source tools for the creative industry, built by Robert Scott-Buccleuch.",
} = Astro.props;

// Stub navigation, honest about what exists at launch (launch-artifacts §6):
// Architecture is the deepest surface; ADRs + standards are folded into one
// "Decisions & Standards" pointer (the adrs. subdomain), not two thin peers;
// Docs points at the separately-built docs. subdomain.
const nav = [
  { href: "/articles", label: "Writing" },
  { href: "/architecture", label: "Architecture" },
  { href: "https://adrs.rsb.sh", label: "Decisions & Standards" },
  { href: "https://docs.rsb.sh", label: "Docs" },
  { href: "/contribute", label: "Contribute" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-white text-neutral-900">
    <header class="mx-auto flex max-w-2xl flex-wrap items-baseline gap-x-6 gap-y-2 px-6 pt-8">
      <a
        href="/"
        class="font-mono text-sm tracking-wide text-neutral-900"
        aria-label="rsb.sh home"
      >
        rsb.sh
      </a>
      <nav
        aria-label="Primary"
        class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-neutral-600"
      >
        {
          nav.map((item) => (
            <a class="transition-colors hover:text-neutral-900" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main class="mx-auto max-w-2xl px-6 py-16">
      <slot />
    </main>
  </body>
</html>
